    "#Factorial num\n",
    "def fact(n):\n",
    "    if(n==0):\n",
    "        return 1\n",
    "    else:\n",
    "        return n * fact(n-1)\n",
    "a = int(input(\"Enter a num: \"))\n",
    "print(fact(a))"
